modules = ["nodejs-20", "python-3.11", "web", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: Django API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/frontend: web"

[[workflows.workflow]]
name = "artifacts/api-server: Django API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python /home/runner/workspace/backend/manage.py runserver 0.0.0.0:8000 --noreload"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/frontend: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5173 BASE_PATH=/ pnpm --filter @workspace/frontend run dev"
waitForPort = 5173

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "pkg-config", "rustc", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
# Secrets are managed via Replit Secrets (OPENAI_API_KEY, TELEGRAM_BOT_TOKEN)
# Do not put credentials here; this file is committed to git.
